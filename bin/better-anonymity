#!/bin/bash

# bin/better-anonymity
# Main CLI entrypoint

# Resolve absolute path to the project root
# Handle symlinks to ensure we find the real lib/ directory
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do 
    DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE" 
done
DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
ROOT_DIR="$(dirname "$DIR")"
LIB_DIR="$ROOT_DIR/lib"

# Check if lib exists
if [ ! -d "$LIB_DIR" ]; then
    echo "Error: Library directory not found at $LIB_DIR"
    exit 1
fi

# Source Core Libraries (Essential)
source "$LIB_DIR/core.sh"
source "$LIB_DIR/platform.sh"

# Initialize capabilities
detect_arch
detect_os_version
detect_model
check_macos

usage() {
    if [ -f "$LIB_DIR/banner.txt" ]; then
        cat "$LIB_DIR/banner.txt"
    fi
     # Indent aggressively to bypass CI terminal truncation (consumes ~9 chars)
    echo "         Usage: better-anonymity [command] [options]"
    echo ""
    echo "Commands:"
    echo "  menu              Interactive menu (default)"
    echo "  harden            Run macOS hardening checks"
    echo "  dns [provider]    Set DNS (quad9, mullvad, cloudflare)"
    echo "  diagnose          Run system diagnosis and scoring"
    echo "  install           Install global CLI aliases (b-a, better-anon)"
    echo "  install [tool]    Install tool (tor, privoxy, gpg)"
    echo "  generate-password Generate a secure passphrase"
    echo "  help              Show this help"
    echo ""
}

# Main Command Dispatch
COMMAND="$1"
shift

case "$COMMAND" in
    menu|"" )
        load_module "menus"
        interactive_menu
        ;;
    harden)
        load_module "checks"
        load_module "macos_hardening"
        hardening_run_all
        ;;
    dns)
        if [[ -z "$1" ]]; then
            error "Usage: better-anonymity dns [quad9|mullvad|cloudflare]"
            exit 1
        fi
        load_module "network"
        network_set_dns "$1"
        ;;
    install)
        TOOL="$1"
        if [ -z "$TOOL" ]; then
             load_module "lifecycle"
             lifecycle_install_cli
        else
            case "$TOOL" in
                tor) 
                    load_module "tor_manager"
                    install_tor 
                    ;;
                privoxy) 
                    load_module "installers"
                    install_privoxy 
                    ;;
                gpg) 
                    load_module "installers"
                    install_gpg 
                    ;;
                dnscrypt) 
                    load_module "installers"
                    install_dnscrypt 
                    ;;
                pingbar) 
                    load_module "installers"
                    install_pingbar 
                    ;;
                unbound) 
                    load_module "installers"
                    install_unbound 
                    ;;
                *) error "Unknown tool: $TOOL" ;;
            esac
        fi
        ;;
    verify-dns)
        load_module "network"
        network_verify_dns
        ;;
    verify-security)
        load_module "macos_hardening"
        hardening_verify
        ;;
    install-firefox)
         load_module "installers"
         install_firefox
         ;;
    install-keepassxc)
         load_module "installers"
         install_keepassxc
         ;;
    harden-firefox)
         load_module "installers"
         harden_firefox
         ;;
    install-tor)
         load_module "installers"
         install_tor_browser
         ;;
    setup-gpg)
         load_module "installers"
         setup_gpg
         ;;
    install-signal)
         load_module "installers"
         install_signal
         ;;
    cleanup-metadata)
         load_module "cleanup"
         cleanup_metadata
         ;;
    vault)
         load_module "vault"
         shift
         case "$1" in
            write|w) vault_write "$2" ;;
            read|r)  vault_read "$2" ;;
            list|l)  vault_list ;;
            *) echo "Usage: better-anonymity vault [write|read|list]" ;;
         esac
         ;;
    backup)
         load_module "backup"
         shift
         case "$1" in
            encrypt) backup_encrypt_dir "$2" "$3" ;;
            decrypt) backup_decrypt_dir "$2" ;;
            volume|create-volume) backup_create_volume "$2" "$3" ;;
            audit|audit-tm) backup_audit_timemachine ;;
            *) echo "Usage: better-anonymity backup [encrypt|decrypt|volume|audit]" ;;
         esac
         ;;
    wifi)
         load_module "wifi"
         shift
         case "$1" in
            audit) wifi_audit ;;
            spoof-mac|spoof) wifi_spoof_mac ;;
            *) echo "Usage: better-anonymity wifi [audit|spoof-mac]" ;;
         esac
         ;;
    ssh)
         load_module "ssh"
         shift
         case "$1" in
            audit-sshd) ssh_check_sshd_status ;;
            harden-sshd) ssh_harden_sshd ;;
            harden-client) ssh_harden_client ;;
            hash-hosts) ssh_hash_hosts ;;
            *) echo "Usage: better-anonymity ssh [audit-sshd|harden-sshd|harden-client|hash-hosts]" ;;
         esac
         ;;
    tor)
         load_module "tor_manager"
         shift
         case "$1" in
            install) tor_install ;;
            start)   tor_service_start ;;
            stop)    tor_service_stop ;;
            restart) tor_service_restart ;;
            proxy-on|enable-proxy) tor_enable_system_proxy ;;
            proxy-off|disable-proxy) tor_disable_system_proxy ;;
            status)  tor_status ;;
            info)    tor_info ;;
            *) 
               echo "Usage: better-anonymity tor [install|start|stop|restart|status|proxy-on|proxy-off]" 
               ;;
         esac
         ;;
    i2p)
         load_module "i2p_manager"
         shift
         case "$1" in
            install) i2p_install ;;
            start)   i2p_start ;;
            stop)    i2p_stop ;;
            restart) i2p_restart ;;
            status)  i2p_status ;;
            console) i2p_console ;;
            info)    i2p_info ;;
            *) 
               echo "Usage: better-anonymity i2p [install|start|stop|restart|status|console|info]" 
               ;;
         esac
         ;;
    misc-harden)
        load_module "macos_hardening"
        hardening_harden_finder
        hardening_disable_bonjour
        hardening_secure_sudoers
        hardening_set_umask
        hardening_disable_analytics
        hardening_remove_guest
        hardening_privacy_tweaks
        hardening_reset_tcc
        ;;
    update-hosts)
        load_module "network"
        network_update_hosts
        ;;
    setup)
        load_module "lifecycle"
        lifecycle_setup
        ;;
    daily)
        load_module "lifecycle"
        lifecycle_daily
        ;;
    update)
        load_module "lifecycle"
        lifecycle_update
        ;;
    diagnose)
        load_module "diagnosis"
        load_module "wifi" # missing dependency for airport check?
        load_module "core" # already sourced
        # Diagnosis uses is_brew_installed, which is in core.
        # It uses check_airport_exists which calls [ -x ].
        # It uses networksetup (system).
        diagnosis_run
        ;;
    generate-password)
        load_module "password_utils"
        input_count="${1:-6}"
        pwd=$(generate_password "$input_count")
        info "Generated Password: $pwd"
        check_strength "$pwd"
        ;;
    help|--help|-h)
        usage
        ;;
    *)
        error "Unknown command: $COMMAND"
        usage
        exit 1
        ;;
esac
