#!/bin/bash

# bin/better-anonymity
# Main CLI entrypoint

# Resolve absolute path to the project root
# Simpler approach: assume bin/ is one level deep
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(dirname "$DIR")"
LIB_DIR="$ROOT_DIR/lib"

# Check if lib exists
if [ ! -d "$LIB_DIR" ]; then
    echo "Error: Library directory not found at $LIB_DIR"
    exit 1
fi

# Source Libraries
source "$LIB_DIR/core.sh"
source "$LIB_DIR/platform.sh"
source "$LIB_DIR/checks.sh"
source "$LIB_DIR/macos_hardening.sh"
source "$LIB_DIR/network.sh"
source "$LIB_DIR/installers.sh"
source "$LIB_DIR/password_utils.sh"
source "$LIB_DIR/cleanup.sh"
source "$LIB_DIR/vault.sh"
source "$LIB_DIR/backup.sh"
source "$LIB_DIR/wifi.sh"
source "$LIB_DIR/wifi.sh"
source "$LIB_DIR/ssh.sh"
source "$LIB_DIR/tor_manager.sh"
source "$LIB_DIR/lifecycle.sh"

# Initialize capabilities
detect_arch
detect_os_version
detect_model
check_macos
# Optional: check_internet

usage() {
    cat << "EOF"
  _          _   _                                                       _ _         
 | |__   ___| |_| |_ ___ _ __     __ _ _ __   ___  _ __  _   _ _ __ ___ (_) |_ _   _ 
 | '_ \ / _ \ __| __/ _ \ '__|___/ _` | '_ \ / _ \| '_ \| | | | '_ ` _ \| | __| | | |
 | |_) |  __/ |_| ||  __/ | |___| (_| | | | | (_) | | | | |_| | | | | | | | |_| |_| |
 |_.__/ \___|\__|\__\___|_|      \__,_|_| |_|\___/|_| |_|\__, |_| |_| |_|_|\__|\__, |
                                                         |___/                 |___/ 
EOF
    echo "Usage: better-anonymity [command] [options]"
    echo ""
    echo "Commands:"
    echo "  menu              Interactive menu (default)"
    echo "  harden            Run macOS hardening checks"
    echo "  dns [provider]    Set DNS (quad9, mullvad, cloudflare)"
    echo "  install [tool]    Install tool (tor, privoxy, gpg)"
    echo "  generate-password Generate a secure passphrase"
    echo "  help              Show this help"
    echo ""
}

interactive_menu() {
    clear
    header "MacOS Security & Privacy Setup"
    echo "1. Run OS Hardening"
    echo "2. Configure DNS"
    echo "3. Install Privoxy"
    echo "4. Install Tor Service & Browser"
    echo "5. Install GPG"
    echo "6. Install DNSCrypt"
    echo "7. Install PingBar"
    echo "8. Install Unbound"
    echo "9. Generate Strong Password"
    echo "10. Update Hosts Blocklist"
    echo "11. Verify DNS Config"
    echo "12. Verify Security Config"
    echo "13. Install Firefox"
    echo "14. Harden Firefox (Arkenfox)"
    echo "15. Install Tor Browser"
    echo "16. Setup GPG"
    echo "17. Install Signal"
    echo "18. Cleanup Metadata & Artifacts"
    echo "19. Password Vault"
    echo "20. Secure Backup Tools"
    echo "21. Wi-Fi Security Tools"
    echo "22. SSH Hardening"
    echo "23. Misc Hardening (Manual)"
    echo "q. Quit"
    echo
    echo -n "Select an option: "
    read -r choice

    case $choice in
        1)
            if ask_confirmation "Run all hardening steps?"; then
                hardening_run_all
            fi
            ;;
        2)
            echo "1) Quad9 2) Mullvad 3) Cloudflare"
            read -r dns_choice
            case $dns_choice in
                1) network_set_dns "quad9" ;;
                2) network_set_dns "mullvad" ;;
                3) network_set_dns "cloudflare" ;;
                *) error "Invalid choice" ;;
            esac
            ;;
        3) install_privoxy ;;
        4) 
             echo "1) Install Tor Browser (App)"
             echo "2) Install Tor Service (CLI)"
             read -p "Select: " tchoice
             case $tchoice in
                1) install_tor_browser ;;
                2) tor_install ;;
             esac
             ;;
        5) install_gpg ;;
        6) install_dnscrypt ;;
        7) install_pingbar ;;
        8) install_unbound ;;
        9)
             pwd=$(generate_password 6)
             info "Generated Password: $pwd"
             check_strength "$pwd"
             ;;
        10)
             network_update_hosts
             ;;
        11)
             network_verify_dns
             ;;
        12)
             hardening_verify
             ;;
        13)
             install_firefox
             ;;
        14)
             harden_firefox
             ;;
        15)
             install_tor_browser
             ;;
        16)
             setup_gpg
             ;;
        17)
             install_signal
             ;;
        18)
             cleanup_metadata
             ;;
        19)
             vault_list # Show list as default action or prompt? Let's prompt submenu or just list
             echo "Vault Commands:"
             echo "  w [name] - Write/Create"
             echo "  r [name] - Read"
             echo "  l        - List"
             read -p "Action (w/r/l): " vaction
             case $vaction in
                w) vault_write ;;
                r) vault_read ;;
                l) vault_list ;;
             esac
             ;;
        20)
             echo "Backup Commands:"
             echo "  encrypt [dir]  - Encrypt Directory"
             echo "  decrypt [file] - Decrypt Archive"
             echo "  volume         - Create Encrypted DMG"
             echo "  audit          - Audit Time Machine"
             read -p "Action: " baction
             case $baction in
                encrypt) backup_encrypt_dir ;;
                decrypt) backup_decrypt_dir ;;
                volume) backup_create_volume ;;
                audit) backup_audit_timemachine ;;
             esac
             ;;
        21)
             echo "Wi-Fi Tools:"
             echo "  1) Audit Connection"
             echo "  2) Spoof MAC Address"
             read -p "Select: " wchoice
             case $wchoice in
                1) wifi_audit ;;
                2) wifi_spoof_mac ;;
             esac
             ;;
        22)
             echo "SSH Tools:"
             echo "  1) Audit SSHD Status"
             echo "  2) Harden SSHD (Server) Config"
             echo "  3) Harden SSH Client Config"
             echo "  4) Hash known_hosts"
             read -p "Select: " schoice
             case $schoice in
                1) ssh_check_sshd_status ;;
                2) ssh_harden_sshd ;;
                3) ssh_harden_client ;;
                4) ssh_hash_hosts ;;
             esac
             ;;
        23)
             echo "Running Miscellaneous Hardening Steps..."
             hardening_harden_finder
             hardening_disable_bonjour
             hardening_secure_sudoers
             hardening_set_umask
             hardening_disable_analytics
             hardening_remove_guest
             hardening_privacy_tweaks
             hardening_reset_tcc
             ;;
        q) exit 0 ;;
        *) error "Invalid option" ;;
    esac
    
    echo
    read -p "Press Enter to return..."
    interactive_menu
}

# Main Command Dispatch
COMMAND="$1"
shift

case "$COMMAND" in
    menu|"" )
        interactive_menu
        ;;
    harden)
        hardening_run_all
        ;;
    dns)
        if [[ -z "$1" ]]; then
            error "Usage: better-anonymity dns [quad9|mullvad|cloudflare]"
            exit 1
        fi
        network_set_dns "$1"
        ;;
    install)
        TOOL="$1"
        case "$TOOL" in
            tor) install_tor ;;
            privoxy) install_privoxy ;;
            gpg) install_gpg ;;
            dnscrypt) install_dnscrypt ;;
            pingbar) install_pingbar ;;
            unbound) install_unbound ;;
            *) error "Unknown tool: $TOOL" ;;
        esac
        ;;
    verify-dns)
        network_verify_dns
        ;;
    verify-security)
        hardening_verify
        ;;
    install-firefox)
         install_firefox
         ;;
    harden-firefox)
         harden_firefox
         ;;
    install-tor)
         install_tor_browser
         ;;
    setup-gpg)
         setup_gpg
         ;;
    install-signal)
         install_signal
         ;;
    cleanup-metadata)
         cleanup_metadata
         ;;
    vault)
         shift
         case "$1" in
            write|w) vault_write "$2" ;;
            read|r)  vault_read "$2" ;;
            list|l)  vault_list ;;
            *) echo "Usage: better-anonymity vault [write|read|list]" ;;
         esac
         ;;
    backup)
         shift
         case "$1" in
            encrypt) backup_encrypt_dir "$2" "$3" ;;
            decrypt) backup_decrypt_dir "$2" ;;
            volume|create-volume) backup_create_volume "$2" "$3" ;;
            audit|audit-tm) backup_audit_timemachine ;;
            *) echo "Usage: better-anonymity backup [encrypt|decrypt|volume|audit]" ;;
         esac
         ;;
    wifi)
         shift
         case "$1" in
            audit) wifi_audit ;;
            spoof-mac|spoof) wifi_spoof_mac ;;
            *) echo "Usage: better-anonymity wifi [audit|spoof-mac]" ;;
         esac
         ;;
    ssh)
         shift
         case "$1" in
            audit-sshd) ssh_check_sshd_status ;;
            harden-sshd) ssh_harden_sshd ;;
            harden-client) ssh_harden_client ;;
            hash-hosts) ssh_hash_hosts ;;
            *) echo "Usage: better-anonymity ssh [audit-sshd|harden-sshd|harden-client|hash-hosts]" ;;
         esac
         ;;
    tor)
         shift
         case "$1" in
            install) tor_install ;;
            start)   tor_service_start ;;
            stop)    tor_service_stop ;;
            restart) tor_service_restart ;;
            proxy-on|enable-proxy) tor_enable_system_proxy ;;
            proxy-off|disable-proxy) tor_disable_system_proxy ;;
            status)  tor_status ;;
            info)    tor_info ;;
            *) 
               echo "Usage: better-anonymity tor [install|start|stop|restart|status|proxy-on|proxy-off]" 
               ;;
         esac
         ;;
    misc-harden)
        hardening_harden_finder
        hardening_disable_bonjour
        hardening_secure_sudoers
        hardening_set_umask
        hardening_disable_analytics
        hardening_remove_guest
        hardening_privacy_tweaks
        hardening_reset_tcc
        ;;
    update-hosts)
        network_update_hosts
        ;;
    setup)
        lifecycle_setup
        ;;
    daily)
        lifecycle_daily
        ;;
    update)
        lifecycle_update
        ;;
    generate-password)
        input_count="${1:-6}"
        pwd=$(generate_password "$input_count")
        info "Generated Password: $pwd"
        check_strength "$pwd"
        ;;
    help|--help|-h)
        usage
        ;;
    *)
        error "Unknown command: $COMMAND"
        usage
        exit 1
        ;;
esac
